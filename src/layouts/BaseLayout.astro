---
import BrandMark from "../components/BrandMark.astro";
import { projects, withBasePath } from "../data/projects";
import "../styles/global.css";

const {
  title = "Nico Abramowski | Technical Portfolio",
  description = "Portfolio of practical software, Android, Linux, scripting, and technical project work by Nico Abramowski.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const overviewHref = base;
const aboutHref = withBasePath(base, "/about");
const cvHref = withBasePath(base, "/CV.pdf");
const navProjects = projects.map((project) => ({
  ...project,
  url: withBasePath(base, project.href),
}));

const isActive = (href: string) => {
  if (href === overviewHref) {
    return path === overviewHref;
  }

  return path === href || path.startsWith(`${href}/`);
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        try {
          document.documentElement.classList.add("js");
          const saved = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

          if (saved === "dark" || (!saved && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (error) {}
      })();
    </script>
  </head>
  <body>
    <header class="mobile-shell">
      <div class="container-xl mobile-shell__bar">
        <a href={overviewHref} class="brand-lockup">
          <BrandMark compact={true} />
          <div class="brand-copy">
            <div class="brand-copy__title">Nico Abramowski</div>
            <div class="brand-copy__meta">Technical Portfolio</div>
          </div>
        </a>

        <div class="mobile-shell__controls">
          <button class="mode-toggle themeToggle" aria-label="Toggle theme">
            <span class="mode-toggle__label">Theme</span>
            <span class="mode-toggle__value" data-theme-label>light</span>
          </button>
          <button id="mobileMenu" class="mode-toggle" aria-label="Menu" aria-controls="mobileNav" aria-expanded="false">
            <span class="mode-toggle__label">Menu</span>
            <span class="mode-toggle__value" data-menu-label>open</span>
          </button>
        </div>
      </div>

      <nav id="mobileNav" class="mobile-drawer hidden">
        <div class="container-xl mobile-drawer__inner">
          <div class="nav-group">
            <div class="nav-group__label">pages</div>
            <a class={`mobile-navlink ${isActive(overviewHref) ? "mobile-navlink-active" : ""}`} href={overviewHref}>Overview</a>
            <a class={`mobile-navlink ${isActive(aboutHref) ? "mobile-navlink-active" : ""}`} href={aboutHref}>About</a>
          </div>

          <div class="nav-group">
            <div class="nav-group__label">projects</div>
            {navProjects.map((project) => (
              <a class={`mobile-navlink ${isActive(project.url) ? "mobile-navlink-active" : ""}`} href={project.url}>
                {project.title}
              </a>
            ))}
          </div>

          <div class="nav-group">
            <div class="nav-group__label">links</div>
            <a class="mobile-navlink" href="https://github.com/Nico-Ab" target="_blank" rel="noreferrer">GitHub</a>
            <a class="mobile-navlink" href={cvHref} download>CV (PDF)</a>
          </div>
        </div>
      </nav>
    </header>

    <div class="workspace-shell">
      <aside class="workspace-sidebar" data-role="workspace-sidebar">
        <div class="sidebar-frame">
          <a href={overviewHref} class="brand-lockup">
            <BrandMark />
            <div class="brand-copy">
              <div class="brand-copy__title">Nico Abramowski</div>
              <div class="brand-copy__meta">Technical Portfolio</div>
            </div>
          </a>

          <div class="sidebar-status panel accent-cyan">
            <span class="schema-label">Current profile</span>
            <p>
              At the end of my Computer Science studies at the University of Rostock, with practical work across software
              implementation, Android, Linux-based workflows, and technical documentation.
            </p>
            <div class="sidebar-status__foot">
              <a class="inline-link" href={aboutHref}>Read the full profile</a>
            </div>
          </div>

          <nav class="sidebar-nav">
            <div class="nav-group">
              <div class="nav-group__label">pages</div>
              <a class={`nav-tab ${isActive(overviewHref) ? "nav-tab-active" : ""}`} href={overviewHref}>
                <span>Overview</span>
                <span class="nav-tab__meta">home</span>
              </a>
              <a class={`nav-tab ${isActive(aboutHref) ? "nav-tab-active" : ""}`} href={aboutHref}>
                <span>About</span>
                <span class="nav-tab__meta">dossier</span>
              </a>
            </div>

            <div class="nav-group">
              <div class="nav-group__label">projects</div>
              {navProjects.map((project) => (
                <a
                  class={`nav-tab accent-${project.accentKey} ${isActive(project.url) ? "nav-tab-active" : ""}`}
                  href={project.url}
                >
                  <span>{project.title}</span>
                  <span class="nav-tab__meta">{project.navMeta}</span>
                </a>
              ))}
            </div>

            <div class="nav-group">
              <div class="nav-group__label">links</div>
              <a class="nav-tab" href="https://github.com/Nico-Ab" target="_blank" rel="noreferrer">
                <span>GitHub</span>
                <span class="nav-tab__meta">source</span>
              </a>
              <a class="nav-tab" href={cvHref} download>
                <span>CV (PDF)</span>
                <span class="nav-tab__meta">download</span>
              </a>
            </div>
          </nav>

          <div class="sidebar-footer">
            <button class="mode-toggle themeToggle" aria-label="Toggle theme">
              <span class="mode-toggle__label">Theme</span>
              <span class="mode-toggle__value" data-theme-label>light</span>
            </button>
          </div>
        </div>
      </aside>

      <main class="workspace-main">
        <div class="workspace-background" aria-hidden="true">
          <div class="workspace-grid"></div>
          <div class="workspace-lines"></div>
          <div class="workspace-scan"></div>
        </div>

        <div class="container-xl page-frame">
          <slot />
        </div>
      </main>
    </div>

    <script>
      (() => {
        const html = document.documentElement;
        const menuBtn = document.getElementById("mobileMenu");
        const mobileNav = document.getElementById("mobileNav");
        const themeLabels = document.querySelectorAll("[data-theme-label]");
        const menuLabels = document.querySelectorAll("[data-menu-label]");

        const syncThemeLabels = () => {
          const themeValue = html.classList.contains("dark") ? "dark" : "light";
          themeLabels.forEach((node) => {
            node.textContent = themeValue;
          });
        };

        const collapseMenu = () => {
          if (!mobileNav) return;

          mobileNav.classList.add("hidden");
          menuBtn?.setAttribute("aria-expanded", "false");
          menuLabels.forEach((node) => {
            node.textContent = "open";
          });
        };

        const toggleMenu = () => {
          if (!mobileNav) return;

          mobileNav.classList.toggle("hidden");

          const isOpen = !mobileNav.classList.contains("hidden");
          menuBtn?.setAttribute("aria-expanded", String(isOpen));
          menuLabels.forEach((node) => {
            node.textContent = isOpen ? "close" : "open";
          });
        };

        try {
          syncThemeLabels();

          document.querySelectorAll(".themeToggle").forEach((button) => {
            button.addEventListener("click", () => {
              html.classList.toggle("dark");
              localStorage.setItem("theme", html.classList.contains("dark") ? "dark" : "light");
              syncThemeLabels();
            });
          });
        } catch (error) {}

        collapseMenu();

        if (menuBtn && mobileNav) {
          menuBtn.addEventListener("click", () => {
            toggleMenu();
          });

          mobileNav.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
              collapseMenu();
            });
          });
        }

        window.addEventListener("resize", () => {
          if (window.innerWidth >= 1024) {
            collapseMenu();
          }
        });

        const revealItems = document.querySelectorAll(".reveal");

        if (!("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16 }
        );

        revealItems.forEach((item) => observer.observe(item));
      })();
    </script>
  </body>
</html>
