---
import type { ProjectRecord } from "../data/projects";

export interface Props {
  project: ProjectRecord;
}

const { project } = Astro.props;
---
<section class={`case-study accent-${project.accentKey}`}>
  <header class="panel case-hero reveal" data-role="project-hero">
    <div class="case-hero__main">
      <div class="eyebrow-row">
        <span class="schema-label">{project.category}</span>
        <span class="meta-inline">{project.evidenceLabel}</span>
      </div>

      <h1 class="case-title">{project.title}</h1>
      <p class="case-summary">{project.summary}</p>

      <div class="hero-actions project-actions">
        {project.links.map((link, index) => (
          <a
            href={link.href}
            class={index === 0 ? "btn-primary" : "btn-secondary"}
            target="_blank"
            rel="noreferrer"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="chip-row case-stack">
        {project.stack.map((item) => (
          <span class="meta-chip">{item}</span>
        ))}
      </div>
    </div>

    <aside class="case-facts" aria-label="Project facts">
      <div class="meta-card case-fact">
        <span class="meta-card__label">Project proof</span>
        <strong class="meta-card__value">{project.evidenceLabel}</strong>
      </div>
      <div class="meta-card case-fact">
        <span class="meta-card__label">Current position</span>
        <p class="case-fact__copy">{project.currentState}</p>
      </div>
    </aside>
  </header>

  <div class="case-grid">
    <article class="panel case-panel reveal">
      <div class="panel-header">
        <span class="schema-label">What it is</span>
      </div>
      <p class="section-copy">{project.whatItIs}</p>
    </article>

    <article class="panel case-panel reveal" style="transition-delay:.05s">
      <div class="panel-header">
        <span class="schema-label">Problem it addresses</span>
      </div>
      <p class="section-copy">{project.problem}</p>
    </article>
  </div>

  <div class="case-grid case-grid--lower">
    <article class="panel case-panel reveal">
      <div class="panel-header">
        <span class="schema-label">What I implemented</span>
      </div>
      <ul class="data-list">
        {project.implemented.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>

    <article class="panel case-panel reveal" style="transition-delay:.05s">
      <div class="panel-header">
        <span class="schema-label">What it demonstrates</span>
      </div>
      <ul class="data-list">
        {project.demonstrates.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </div>
</section>
