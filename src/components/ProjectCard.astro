---
import type { ProjectRecord } from "../data/projects";

export interface Props {
  project: ProjectRecord;
  href?: string;
}

const { project, href = project.href } = Astro.props;
---
<a
  href={href}
  class={`project-card panel accent-${project.accentKey}`}
  data-role="project-card"
  data-accent={project.accentKey}
>
  <div class="project-card__trace" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="project-card__header">
    <span class="schema-label">{project.category}</span>
    <span class="meta-inline">{project.statusLabel}</span>
  </div>

  <h3 class="project-card__title">{project.title}</h3>
  <p class="project-card__summary">{project.summary}</p>

  <div class="project-card__footer">
    <div class="chip-row">
      {project.stack.map((item) => (
        <span class="meta-chip">{item}</span>
      ))}
    </div>
    <span class="project-card__open">view notes</span>
  </div>
</a>
