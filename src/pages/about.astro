---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBasePath } from "../data/projects";

const base = import.meta.env.BASE_URL;
const focusAreas = [
  "Kimball-style dimensions and facts, SCD strategies, pragmatic naming, and testable model design.",
  "dbt for transformations, incremental patterns, and orchestration foundations with Airflow or Prefect.",
  "Data-quality checks and lightweight contracts that stop regressions before they spread.",
  "Compact dashboards and docs that answer a clear business question instead of showing everything at once.",
];
const toolbox = [
  "SQL and warehouses: PostgreSQL and DuckDB.",
  "Transformation: dbt.",
  "Python: pandas plus small ETL / ELT utilities.",
  "Platform: Docker, Git, and Linux Mint.",
  "Streaming foundations: Kafka and Debezium.",
];
---
<BaseLayout title="About | Nico Abramowski">
  <section class="about-grid">
    <article class="panel dossier-summary accent-amber reveal">
      <div class="eyebrow-row">
        <span class="schema-label">candidate dossier</span>
        <span class="status-pill">Open to entry-level roles</span>
      </div>

      <h1 class="case-title">About Nico</h1>
      <p class="case-summary">
        I'm Nico Abramowski, a B.Sc. Computer Science candidate at the University of Rostock. I'm building a career in
        data warehousing and analytics engineering, with a bias toward clear dimensional models, reliable ELT flows, and
        documentation that helps people trust what they are looking at.
      </p>

      <div class="hero-meta-grid about-meta-grid">
        <div class="meta-card">
          <span class="meta-card__label">Location</span>
          <strong class="meta-card__value">Blagoevgrad, Bulgaria</strong>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Studies</span>
          <strong class="meta-card__value">B.Sc. Computer Science</strong>
        </div>
        <div class="meta-card">
          <span class="meta-card__label">Bias</span>
          <strong class="meta-card__value">Reliable, readable systems</strong>
        </div>
      </div>
    </article>

    <aside class="panel dossier-panel accent-cyan reveal" style="transition-delay:.05s">
      <div class="panel-header">
        <span class="schema-label">contact endpoints</span>
        <span class="meta-inline">where to reach me</span>
      </div>

      <div class="contact-list">
        <div class="contact-row">
          <span class="contact-row__label">Email</span>
          <a class="inline-link" href="mailto:nico.abramowski01@gmail.com">nico.abramowski01@gmail.com</a>
        </div>
        <div class="contact-row">
          <span class="contact-row__label">GitHub</span>
          <a class="inline-link" href="https://github.com/Nico-Ab" target="_blank" rel="noreferrer">Nico-Ab</a>
        </div>
        <div class="contact-row">
          <span class="contact-row__label">LinkedIn</span>
          <a class="inline-link" href="https://www.linkedin.com/in/nico-abramowski-0aa460383" target="_blank" rel="noreferrer">
            nico-abramowski-0aa460383
          </a>
        </div>
        <div class="contact-row">
          <span class="contact-row__label">CV</span>
          <a class="inline-link" href={withBasePath(base, "/CV.pdf")} download>Download PDF</a>
        </div>
      </div>
    </aside>
  </section>

  <section class="dossier-grid">
    <article class="panel dossier-panel reveal">
      <div class="panel-header">
        <span class="schema-label">focus_areas</span>
        <span class="meta-inline">current engineering interests</span>
      </div>
      <ul class="data-list">
        {focusAreas.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>

    <article class="panel dossier-panel accent-jade reveal" style="transition-delay:.04s">
      <div class="panel-header">
        <span class="schema-label">toolbox</span>
        <span class="meta-inline">working stack</span>
      </div>
      <ul class="data-list">
        {toolbox.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>

    <article class="panel dossier-panel accent-steel reveal" style="transition-delay:.08s">
      <div class="panel-header">
        <span class="schema-label">background</span>
        <span class="meta-inline">previous technical context</span>
      </div>
      <p class="dossier-copy">
        Prior work included Linux networking, TSN / SDN, and scripting. That background shaped my preference for
        repeatable systems, operational clarity, and designs that remain easy to inspect when something goes wrong.
      </p>
    </article>

    <article class="panel dossier-panel accent-cyan reveal" style="transition-delay:.12s">
      <div class="panel-header">
        <span class="schema-label">what_i_am_looking_for</span>
        <span class="meta-inline">next role</span>
      </div>
      <p class="dossier-copy">
        Entry-level roles in data warehousing or analytics engineering. I want to help ship clean models, tested
        transformations, and dashboards that are grounded in the warehouse rather than disconnected from it.
      </p>
    </article>
  </section>
</BaseLayout>
