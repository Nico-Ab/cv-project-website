---
import BrandMark from "../components/BrandMark.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, withBasePath } from "../data/projects";

const base = import.meta.env.BASE_URL;
const focusCards = [
  { label: "Studies", value: "At the end of my Computer Science studies at the University of Rostock" },
  { label: "Implemented work", value: "Erasmus portal and a Kotlin Android learning app" },
  { label: "Working style", value: "Linux, scripting, documentation, and structured debugging" },
  { label: "Role fit", value: "Junior software, web, QA automation, platform, and technical roles" },
];
const implementedWork = [
  {
    id: "WEB",
    title: "Practical web application work",
    detail: "Role-based workflows, structured forms, document handling, reporting, and reproducible local setup.",
  },
  {
    id: "APP",
    title: "Android app development",
    detail: "Kotlin, Jetpack Compose, local persistence, and product logic that goes beyond simple screen wiring.",
  },
  {
    id: "SYS",
    title: "Linux and systems work",
    detail: "Scripting, troubleshooting, reproducible environments, and lower-level technical implementation.",
  },
];
const technicalStrengths = [
  "I prefer clear structure, readable code, and setups that can be reproduced later without guesswork.",
  "When something breaks, I like to debug methodically and document both the cause and the fix.",
  "My background in Computer Science has given me a strong foundation for moving between software, data, and system-oriented work.",
];
---
<BaseLayout
  title="Nico Abramowski | Technical Portfolio"
  description="Portfolio of practical software, Android, Linux, scripting, and technical project work by Nico Abramowski."
>
  <section class="home-hero">
    <article class="panel hero-panel accent-amber reveal">
      <div class="eyebrow-row">
        <span class="schema-label">technical portfolio</span>
        <span class="status-pill">Open to junior roles</span>
      </div>

      <div class="hero-heading">
        <BrandMark compact={true} />
        <h1 class="hero-title">
          Software and technical work I can <span class="text-gradient">build, debug, and explain</span> clearly.
        </h1>
      </div>

      <p class="hero-copy">
        I'm Nico Abramowski, at the end of my Computer Science studies at the University of Rostock. My recent
        implemented work includes an Erasmus staff mobility portal for South-West University, a German learning app in
        Kotlin and Android Studio, and Linux-based scripting and documentation. I'm looking for junior roles where
        careful implementation and technical reliability matter.
      </p>

      <div class="hero-actions">
        <a href={withBasePath(base, "/about")} class="btn-primary">Open dossier</a>
        <a href={withBasePath(base, "/CV.pdf")} class="btn-secondary" download>Download CV</a>
      </div>

      <div class="hero-meta-grid">
        {focusCards.map((item) => (
          <div class="meta-card">
            <span class="meta-card__label">{item.label}</span>
            <strong class="meta-card__value">{item.value}</strong>
          </div>
        ))}
      </div>
    </article>

    <article class="panel query-console hero-console accent-cyan reveal" data-role="query-console">
      <div class="query-console__bar">
        <div class="query-console__dots">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="schema-label">profile/current_work.md</span>
      </div>
      <div class="query-console__body">
        <div class="query-line query-line--accent">implemented_work: "Erasmus staff mobility portal"</div>
        <div class="query-line">android_project: "German Learning App"</div>
        <div class="query-line">environment: "Linux, Git, scripting, documentation"</div>
        <div class="query-line">strength: "structured debugging and reproducibility"</div>
        <div class="query-line query-line--muted">foundation: "Computer Science, University of Rostock"</div>
        <div class="query-line query-line--accent">approach: "careful, practical, clear"<span class="query-cursor"></span></div>
      </div>
      <div class="query-console__footer">
        Practical implementation, clear documentation, and technical work that can be understood and maintained.
      </div>
    </article>
  </section>

  <section class="home-bottom">
    <article class="panel backlog-panel accent-jade reveal">
      <div class="panel-header">
        <span class="schema-label">implemented work</span>
        <span class="meta-inline">recent practical experience</span>
      </div>
      <div class="backlog-list">
        {implementedWork.map((item) => (
          <div class="backlog-row">
            <span class="backlog-row__id">{item.id}</span>
            <div>
              <strong>{item.title}</strong>
              <p>{item.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </article>

    <article class="panel backlog-panel accent-steel reveal" style="transition-delay:.05s">
      <div class="panel-header">
        <span class="schema-label">technical approach</span>
        <span class="meta-inline">how I like to work</span>
      </div>
      <ul class="data-list">
        {technicalStrengths.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section-heading reveal">
    <div>
      <span class="schema-label">projects</span>
      <h2>Selected projects</h2>
    </div>
    <p>
      A smaller set of case studies focused on real implemented work. Each page explains the problem, the actual
      implementation, the stack used, and what the project shows about how I work.
    </p>
  </section>

  <div class="project-grid">
    {projects.map((project, index) => (
      <div class="reveal" style={`transition-delay:${index * 0.04}s`}>
        <ProjectCard project={project} href={withBasePath(base, project.href)} />
      </div>
    ))}
  </div>
</BaseLayout>
